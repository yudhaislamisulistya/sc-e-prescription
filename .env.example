# .env.example - copy to .env and fill in. `docker compose` reads .env automatically.
# ---------------------------------------------------------------------------

# --- Compose profiles -------------------------------------------------------
# FIRST boot: leave empty -> only infra starts (besu, postgres, redis, ipfs).
# After deploying the contracts and filling the addresses below, set this to
# "app" so `docker compose up -d` also starts indexer + kms-signer + nextjs-app.
COMPOSE_PROFILES=

# --- Deployed contract addresses (fill after the hardhat deploy) ------------
# Server-side (read by indexer / kms-signer / nextjs-app API routes).
IDENTITY_REGISTRY_ADDRESS=
PRESCRIPTION_REGISTRY_ADDRESS=
KEY_ACCESS_REGISTRY_ADDRESS=

# Client-side (inlined into the browser bundle at BUILD time -> must be set
# before `docker compose --profile app build`). Use the SAME addresses.
# NEXT_PUBLIC_RPC_URL must be a URL the BROWSER can reach (not the loopback
# besu-rpc); e.g. a TLS reverse proxy in front of the RPC.
NEXT_PUBLIC_CHAIN_ID=1337
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_IDENTITY_REGISTRY_ADDRESS=
NEXT_PUBLIC_PRESCRIPTION_REGISTRY_ADDRESS=
NEXT_PUBLIC_KEY_ACCESS_REGISTRY_ADDRESS=

# --- Indexer ----------------------------------------------------------------
START_BLOCK=0
INDEXER_CONFIRMATIONS=0

# --- Host ports (override only if the 133xx defaults clash on this host) ----
# WEB_PORT=13300
# IPFS_GATEWAY_PORT=13301
# BESU_RPC_PORT=13302
# IPFS_API_PORT=13303
# BESU_P2P_PORT=13304
# IPFS_CLUSTER_PORT=13305

# --- Contract deploy (used by `npx hardhat ... --network besu`, NOT compose) -
# BESU_RPC_URL=http://127.0.0.1:13302
# DEPLOYER_PRIVATE_KEY=0x...   # from infra/besu/generate-keys.sh
