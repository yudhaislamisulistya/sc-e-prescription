# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/coverage.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Hardhat files
/cache
/artifacts

# TypeChain files
/typechain
/typechain-types

# Hardhat Ignition default folder for deployments against a local node
ignition/deployments/chain-31337

# Sensitive data — never commit (V1 containment)
public/data/*.json
secrets/
gas-report.txt

# Besu consortium key material — generated by infra/besu/generate-keys.sh.
# These contain validator sealing + deployer EOA private keys and MUST NEVER
# be committed. The committed genesis.json ships placeholder strings only.
infra/besu/validator-key
infra/besu/deployer-private-key.txt
infra/besu/networkFiles/
infra/besu/ibftConfigFile.json
# static-nodes.json is host-specific (contains the validator enode after key gen).
infra/besu/static-nodes.json
.gstack/
